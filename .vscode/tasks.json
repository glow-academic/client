{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Database: Start",
      "type": "shell",
      "command": "bash",
      "args": ["run.sh", "--clean"],
      "options": {
        "cwd": "${workspaceFolder}/database"
      },
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Client: Start Development",
      "type": "shell",
      "command": "yarn",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Server: Start Development",
      "type": "shell",
      "command": "make",
      "args": ["run"],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Client: Test",
      "type": "shell",
      "command": "yarn",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "test"
    },
    {
      "label": "Server: Test",
      "type": "shell",
      "command": "make",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "group": "test"
    },
    {
      "label": "Client: Test Cypress",
      "type": "shell",
      "command": "yarn",
      "args": ["run", "test:cypress"],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "test"
    },
    {
      "label": "Client: Type Check",
      "type": "shell",
      "command": "npx",
      "args": ["tsc", "--noEmit"],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "build"
    },
    {
      "label": "Server: Type Check",
      "type": "shell",
      "command": "make",
      "args": ["typecheck"],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "group": "build"
    }
  ]
}