{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Database: Start",
      "type": "shell",
      "command": "bash",
      "args": [
        "run.sh",
        "--clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}/database"
      },
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Client: Start Development",
      "type": "shell",
      "command": "yarn",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Server: Start Development",
      "type": "shell",
      "command": "make",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Client: Test",
      "type": "shell",
      "command": "yarn",
      "args": [
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "test"
    },
    {
      "label": "Server: Test",
      "type": "shell",
      "command": "make",
      "args": [
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "group": "test"
    },
    {
      "label": "Client: Test Cypress",
      "type": "shell",
      "command": "yarn",
      "args": [
        "run",
        "test:cypress"
      ],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "test"
    },
    {
      "label": "Client: Type Check",
      "type": "shell",
      "command": "npx",
      "args": [
        "tsc",
        "--noEmit"
      ],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "group": "build"
    },
    {
      "label": "Server: Type Check",
      "type": "shell",
      "command": "make",
      "args": [
        "typecheck"
      ],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "group": "build"
    },
          {
        "type": "typescript",
        "tsconfig": "client/tsconfig.json",
        "problemMatcher": [
          "$tsc"
        ],
        "group": "build",
        "label": "tsc: build - client/tsconfig.json"
      },
      {
        "label": "eslint: lint - client",
        "type": "shell",
        "command": "${workspaceFolder}/client/node_modules/.bin/eslint",
        "args": [
          ".",
          "--format=stylish"
        ],
        "options": {
          "cwd": "${workspaceFolder}/client"
        },
        "group": "build",
        "problemMatcher": "$eslint-stylish",
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared",
          "showReuseMessage": true,
          "clear": false
        }
      },
      {
        "label": "eslint: fix - client",
        "type": "shell",
        "command": "${workspaceFolder}/client/node_modules/.bin/eslint",
        "args": [
          ".",
          "--fix",
          "--format=stylish"
        ],
        "options": {
          "cwd": "${workspaceFolder}/client"
        },
        "group": "build",
        "problemMatcher": "$eslint-stylish",
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared",
          "showReuseMessage": true,
          "clear": false
        }
      }
  ]
}