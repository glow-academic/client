# =============================================================================
# Glow Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   make deploy
# =============================================================================

# -----------------------------------------------------------------------------
# Instance
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=glow
CLIENT_PORT=3000

# -----------------------------------------------------------------------------
# Domain
# -----------------------------------------------------------------------------
ORIGIN=http://localhost:3000
APP_PREFIX=
NEXT_PUBLIC_APP_PREFIX=

# -----------------------------------------------------------------------------
# Institution
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CAMPUS=University Name

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_USER=myuser
DB_PASSWORD=mypassword
DB_NAME=mydb
DB_HOST=localhost
DB_PORT=5432
DB_OPERATION=auto
COMPOSE_BAKE=true

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# auto-generated if blank
AUTH_SECRET=
# auto-generated if blank
SECRET_KEY=
AUTH_URL=http://localhost:3000/api/auth
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=master
AUTH_KEYCLOAK_ID=glow-client
AUTH_KEYCLOAK_SECRET=
KEYCLOAK_PUBLIC_URL=http://localhost:3000/auth
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:3000/auth
NEXT_PUBLIC_AUTH_KEYCLOAK_ID=glow-client

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# Network (defaults — overridden inside Docker)
# -----------------------------------------------------------------------------
INTERNAL_API_BASE=http://localhost:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# -----------------------------------------------------------------------------
# API Keys (encrypted into DB via make bootstrap-keys)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Seed
# -----------------------------------------------------------------------------
SEED_SETUP=university
