{
  "name": "database",
  "version": "1.0.0",
  "description": "glow database management",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "bash scripts/start.sh",
    "start:clean": "bash scripts/start.sh --clean",
    "migrate": "bash scripts/start.sh --migrate",
    "migrate:all": "bash scripts/start.sh --migrate-all",
    "connect": "bash scripts/start.sh --connect",
    "query": "bash scripts/sql-helpers.sh",
