{{ $project := .Env.COMPOSE_PROJECT_NAME }}

upstream blue_app {
{{ range $c := $ }}
  {{ if and $c.State.Running (eq (index $c.Labels "com.docker.compose.service") "app-blue") (eq (index $c.Labels "com.docker.compose.project") $project) }}
    server {{ $c.Name }}:3000 max_fails=3 fail_timeout=30s;
  {{ end }}
{{ end }}
    server 127.0.0.1:1 down;
}

upstream green_app {
{{ range $c := $ }}
  {{ if and $c.State.Running (eq (index $c.Labels "com.docker.compose.service") "app-green") (eq (index $c.Labels "com.docker.compose.project") $project) }}
    server {{ $c.Name }}:3000 max_fails=3 fail_timeout=30s;
  {{ end }}
{{ end }}
    server 127.0.0.1:1 down;
}
