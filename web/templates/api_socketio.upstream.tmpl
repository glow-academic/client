{{ $project := .Env.COMPOSE_PROJECT_NAME }}
{{ range $c := $ }}
  {{ if and $c.State.Running (eq (index $c.Labels "com.docker.compose.service") "server") (eq (index $c.Labels "com.docker.compose.project") $project) }}
    server {{ $c.Name }}:8000 max_fails=3 fail_timeout=30s;
  {{ end }}
{{ end }}
