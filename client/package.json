    "tus-js-client": "^4.3.1",
    "uuid": "^11.1.0",
    "webpack": "^5.100.1",
    "zod": "3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "cypress": "^14.3.3",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4",
    "ts-morph": "^26.0.0",
