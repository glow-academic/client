{
  "name": "glow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx drizzle-kit pull && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:headless": "cypress run --headless",
    "test:e2e": "./cypress/scripts/test-setup.sh -t",
    "test:e2e:headless": "cypress run",
    "test:core": "cypress run --spec 'cypress/e2e/core-comprehensive.cy.ts'",
    "test:login": "cypress run --spec 'cypress/e2e/core-auth.cy.ts'",
    "test:chat": "cypress run --spec 'cypress/e2e/core-chat.cy.ts'",
    "test:management": "cypress run --spec 'cypress/e2e/core-management.cy.ts'",
    "test:management:open": "cypress open --e2e --spec 'cypress/e2e/core-management.cy.ts'",
    "test:navigation": "cypress run --spec 'cypress/e2e/core-navigation.cy.ts'",
    "test:setup": "./cypress/scripts/test-setup.sh",
    "services:stop": "./cypress/scripts/stop-services.sh",
    "services:restart": "./cypress/scripts/restart-services.sh",
    "test:clean": "./cypress/scripts/clean-test.sh",
    "test:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run test:e2e:headless\"",
    "test:dev:open": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run cypress:open\"",
    "migrate:dev": "drizzle-kit migrate:dev",
    "db:pull": "drizzle-kit pull"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.13",
    "@radix-ui/react-progress": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.4",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.76.0",
    "@tanstack/react-table": "^8.21.3",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "framer-motion": "^12.12.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "next": "15.3.2",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.5",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^2.6.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^2.0.0",
    "tus-js-client": "^4.3.1",
    "vitest": "^3.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20",
    "@types/pg": "^8.15.1",
    "@types/react": "^19",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "cypress": "^14.3.3",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.2.9",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
}
