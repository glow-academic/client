{
  "name": "glow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.17.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit --strict",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint --dir app --dir components --dir utils --dir hooks --dir lib --dir contexts",
    "lint:fix": "next lint --fix --dir app --dir components --dir utils --dir hooks --dir lib --dir contexts",
    "format": "prettier --write .",
    "gen:types": "openapi-typescript ../server/openapi.json -o lib/api/schema.ts",
    "watch:openapi": "chokidar ../server/openapi.json -c \"yarn gen:types\"",
    "watch:sql-types": "chokidar '../server/app/sql/**/*.sql' '../server/tests/sql/**/*.sql' -c 'node scripts/watch-sql-types.js {path}'"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.9.1",
    "@auth/pg-adapter": "^1.9.1",
    "@monaco-editor/react": "^4.7.0",
